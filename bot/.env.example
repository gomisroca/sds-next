# Your Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# Shared secret between the bot and the Next.js app — must match BOT_SECRET in your Next.js .env
BOT_SECRET=

# The base URL of your Next.js app (no trailing slash)
# Local: http://localhost:3000
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# Port for the bot's Express API (Next.js will call this as BOT_URL)
PORT=3001
