generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── NextAuth required tables ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // The Discord account linked via OAuth
  accounts Account[]
  sessions Session[]

  // FC-specific
  role        Role              @default(MEMBER)
  events      Event[]           @relation("CreatedEvents")
  attendances EventAttendance[]
  profile     Profile?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum Job {
  PLD // Paladin
  WAR // Warrior
  DRK // Dark Knight
  GNB // Gunbreaker

  // Healers
  WHM // White Mage
  SCH // Scholar
  AST // Astrologian
  SGE // Sage

  // Melee DPS
  MNK // Monk
  DRG // Dragoon
  NIN // Ninja
  SAM // Samurai
  RPR // Reaper
  VPR // Viper

  // Physical Ranged DPS
  BRD // Bard
  MCH // Machinist
  DNC // Dancer

  // Magical Ranged DPS
  BLM // Black Mage
  SMN // Summoner
  RDM // Red Mage
  PCT // Pictomancer
  BLU // Blue Mage (Limited Job)

  // Crafters
  CRP // Carpenter
  BSM // Blacksmith
  ARM // Armorer
  GSM // Goldsmith
  LTW // Leatherworker
  WVR // Weaver
  ALC // Alchemist
  CUL // Culinarian

  // Gatherers
  MIN // Miner
  BTN // Botanist
  FSH // Fisher
}

enum Activity {
  // Combat
  RAIDING
  SAVAGE
  ULTIMATE
  EXTREME_TRIALS
  DUNGEONS
  ALLIANCE_RAIDS
  DEEP_DUNGEONS
  VARIANT_DUNGEONS
  CRITERION_DUNGEONS
  PVP
  FRONTLINE
  CRYSTALLINE_CONFLICT
  RIVAL_WINGS
  HUNTS
  FATES
  BLUE_MAGE

  // Social
  ROLEPLAY
  VENUES
  COMMUNITY_EVENTS
  FC_EVENTS
  SOCIALIZING
  GPOSE

  // Casual / Exploration
  MSQ
  SIDE_QUESTS
  TREASURE_MAPS
  ACHIEVEMENTS
  COLLECTION

  // Crafting & Gathering
  CRAFTING
  GATHERING
  FISHING
  MARKETBOARD

  // Gold Saucer
  GOLD_SAUCER
  TRIPLE_TRIAD
  MAHJONG
  CHOCOBO_RACING

  // Housing & Island
  HOUSING
  ISLAND_SANCTUARY

  // Misc
  MENTORING
  ROULETTES
  GLAMOUR
}

enum Playstyle {
  CASUAL
  MIDCORE
  HARDCORE
  ROLEPLAYER
  SOCIAL
  COLLECTOR
}

model Profile {
  id     String @id @default(cuid())
  userId String @unique

  // Identity
  name String
  bio  String?

  // Visuals
  portrait String?
  banner   String?

  // Gameplay
  job        Job
  activities Activity[]
  playstyle  Playstyle

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profile")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── FC-specific models ───────────────────────────────────────────────────────

enum Role {
  MEMBER
  OFFICER
  LEADER
}

enum EventStatus {
  DRAFT // not yet posted to Discord
  PUBLISHED // live, accepting RSVPs
  CANCELLED
  COMPLETED
}

enum AttendanceStatus {
  ATTENDING
  NOT_ATTENDING
  MAYBE
}

model Event {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core info
  name        String
  description String?
  location    String? // "Estate Yard" or a zone name
  imageUrl    String? // banner image for the event card
  startsAt    DateTime
  endsAt      DateTime?

  status EventStatus @default(DRAFT)

  // Who created it (must be OFFICER or LEADER)
  createdById String
  createdBy   User   @relation("CreatedEvents", fields: [createdById], references: [id])

  // Discord integration
  discordChannelId String? // channel the message was posted in
  discordMessageId String? // message ID for edits

  attendances EventAttendance[]

  @@map("events")
}

model EventAttendance {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  eventId String
  userId  String
  status  AttendanceStatus

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One row per user per event
  @@unique([eventId, userId])
  @@map("event_attendances")
}
